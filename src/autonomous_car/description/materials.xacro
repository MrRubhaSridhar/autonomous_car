<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>

  <material name="grey">
    <color rgba="0.7 0.7 0.7 1"/>
  </material>

  <material name="blue">
    <color rgba="0.15 0.35 0.85 1"/>
  </material>

  <material name="red">
    <color rgba="0.9 0.1 0.1 1"/>
  </material>

  <material name="green">
    <color rgba="0.1 0.8 0.1 1"/>
  </material>

</robot>
